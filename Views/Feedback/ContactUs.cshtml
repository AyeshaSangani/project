@page
@model eproject.Views.Support.ContactUsModel
@{
}

<div class="text-center mb-4">
    <div class="page-title">Contact Us</div>
</div>

<div class="row g-4 mb-5">
    <div class="col-lg-6">

        <div class="contact-card mb-4">
            <div class="d-flex">
                <i class="bi bi-geo-alt icon-blue me-3"></i>
                <div>
                    <h6 class="fw-bold text-primary">Our Office</h6>
                    <p class="text-muted">
                        123 Tech Park, Sector 5<br>
                        Electronic City, Phase 1<br>
                        Bangalore, KA 560100
                    </p>
                </div>
            </div>
        </div>

        <div class="contact-card mb-4">
            <div class="d-flex">
                <i class="bi bi-telephone icon-blue me-3"></i>
                <div>
                    <h6 class="fw-bold text-primary">Phone</h6>
                    <p class="text-muted">
                        Toll Free: 1800-123-4567<br>
                        Support: +91 98765 43210
                    </p>
                </div>
            </div>
        </div>

        <div class="contact-card">
            <div class="d-flex">
                <i class="bi bi-envelope icon-blue me-3"></i>
                <div>
                    <h6 class="fw-bold text-primary">Email</h6>
                    <p class="text-muted">
                        General: info@onlinemobile.com<br>
                        Support: help@onlinemobile.com
                    </p>
                </div>
            </div>
        </div>

    </div>

    <div class="col-lg-6">
        <div class="business-box h-100">
            <h5 class="fw-bold text-primary mb-4">Business Hours</h5>

            <div class="d-flex justify-content-between border-bottom py-2">
                <span>Monday - Friday</span>
                <span>9:00 AM - 8:00 PM</span>
            </div>
            <div class="d-flex justify-content-between border-bottom py-2">
                <span>Saturday</span>
                <span>10:00 AM - 6:00 PM</span>
            </div>
            <div class="d-flex justify-content-between py-2 mb-3">
                <span>Sunday</span>
                <span>Closed</span>
            </div>

            <div class="business-note">
                <i class="bi bi-clock me-2"></i>
                Our online services are available 24/7.
            </div>
        </div>
    </div>
</div>
